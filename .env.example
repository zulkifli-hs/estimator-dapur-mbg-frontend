# =============================================================================
# Backend
# =============================================================================

# Base URL of the backend API (inlined at build time for client-side usage)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# =============================================================================
# Basic Auth — Client-side API calls
# These are bundled into the browser build. NEXT_PUBLIC_ prefix is required.
# =============================================================================

NEXT_PUBLIC_BASIC_AUTH_USERNAME=your_username
NEXT_PUBLIC_BASIC_AUTH_PASSWORD=your_password

# =============================================================================
# Basic Auth — Server-side upload proxy (Next.js API Route: /api/upload)
# These are NOT exposed to the browser. Never add NEXT_PUBLIC_ prefix here.
# =============================================================================

BASIC_AUTH_USERNAME=your_username
BASIC_AUTH_PASSWORD=your_password
